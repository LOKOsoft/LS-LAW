// LEXORA — practice management data model.
// Local-only SQLite datasource; no external services.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────

enum Role {
  MANAGING_PARTNER
  SENIOR_PARTNER
  PARTNER
  ASSOCIATE
  JUNIOR_ASSOCIATE
  LEGAL_RESEARCHER
  PARALEGAL
  RECEPTION
  ACCOUNTS
  HR
  OFFICE_MANAGER
  ADMINISTRATOR
  CLIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ClientType {
  INDIVIDUAL
  COMPANY
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  ARCHIVED
}

enum MatterStatus {
  INTAKE
  ACTIVE
  ON_HOLD
  CLOSED
  ARCHIVED
}

enum BillingType {
  HOURLY
  FIXED_FEE
  CONTINGENCY
  RETAINER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MatterTeamRole {
  LEAD
  ASSOCIATE
  PARALEGAL
  SUPPORT
}

enum HearingStatus {
  SCHEDULED
  COMPLETED
  ADJOURNED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum DocumentStatus {
  DRAFT
  REVIEW
  PARTNER_APPROVAL
  CLIENT_APPROVAL
  SIGNED
  FILED
  FINAL
  ARCHIVED
  SHARED
}

/**
 * Operational pipeline a matter moves through, from first inquiry to archive. Coarser than MatterStatus.
 */
enum MatterStage {
  INQUIRY
  CONFLICT_CHECK
  CONSULTATION
  MATTER_CREATED
  DOCUMENT_COLLECTION
  RESEARCH
  DRAFTING
  INTERNAL_REVIEW
  CLIENT_REVIEW
  APPROVAL
  FILING
  COURT_HEARING
  ORDER
  BILLING
  PAYMENT
  CLOSURE
  ARCHIVE
}

enum TemplateCategory {
  EMPLOYMENT
  CORPORATE
  LITIGATION
  PROPERTY
  TAX
  COMPLIANCE
  CONTRACTS
  NDA
  AGREEMENT
  NOTICE
  AFFIDAVIT
  POWER_OF_ATTORNEY
  WILL
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum LineItemType {
  FEE
  EXPENSE
}

enum PaymentMethod {
  BANK_TRANSFER
  CHEQUE
  CASH
  CARD
  UPI
}

enum RetainerStatus {
  ACTIVE
  DEPLETED
  CLOSED
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum CommunicationType {
  EMAIL
  CALL
  MEETING
  LETTER
  SMS
}

enum AnnouncementPriority {
  NORMAL
  IMPORTANT
  URGENT
}

enum CourtType {
  SUPREME_COURT
  HIGH_COURT
  DISTRICT_COURT
  TRIBUNAL
  CONSUMER_FORUM
  FAMILY_COURT
  ARBITRATION
}

enum CaseStage {
  FILING
  PRE_TRIAL
  TRIAL
  ARGUMENTS
  JUDGMENT_RESERVED
  DISPOSED
  APPEAL
}

enum NotificationType {
  DEADLINE
  HEARING
  TASK_ASSIGNED
  INVOICE
  DOCUMENT
  MENTION
  SYSTEM
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  WORK_FROM_HOME
  ON_LEAVE
}

// ─────────────────────────────────────────────────────────────────────────
// Firm / org structure
// ─────────────────────────────────────────────────────────────────────────

model Firm {
  id                 String   @id @default(cuid())
  name               String
  legalName          String?
  tagline            String?
  logoUrl            String?
  email              String?
  phone              String?
  website            String?
  addressLine1       String?
  addressLine2       String?
  city               String?
  state              String?
  country            String?
  postalCode         String?
  taxId              String?
  foundedYear        Int?
  timezone           String   @default("Asia/Kolkata")
  currency           String   @default("INR")
  invoicePrefix      String   @default("INV")
  invoiceNextNumber  Int      @default(1)
  financialYearStart Int      @default(4)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  offices Office[]
}

model Office {
  id           String   @id @default(cuid())
  firmId       String
  firm         Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  name         String
  isPrimary    Boolean  @default(false)
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  country      String?
  postalCode   String?
  phone        String?
  email        String?
  createdAt    DateTime @default(now())

  users User[]
}

model PracticeArea {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  color       String  @default("#6366f1")
  icon        String?

  matters Matter[]
}

model User {
  id                String     @id @default(cuid())
  name              String
  email             String     @unique
  passwordHash      String
  phone             String?
  role              Role
  title             String?
  avatarUrl         String?
  barNumber         String?
  status            UserStatus @default(ACTIVE)
  utilizationTarget Int        @default(75)
  joinedAt          DateTime   @default(now())
  officeId          String?
  office            Office?    @relation(fields: [officeId], references: [id])
  clientId          String?
  portalClient      Client?    @relation("PortalUser", fields: [clientId], references: [id])

  matterMemberships          MatterTeamMember[]
  responsibleMatters         Matter[]                   @relation("ResponsibleAttorney")
  relationshipClients        Client[]                   @relation("RelationshipManager")
  assignedTasks              Task[]                     @relation("TaskAssignee")
  createdTasks               Task[]                     @relation("TaskCreator")
  documentsUploaded          DocumentFile[]
  documentsReviewed          DocumentFile[]             @relation("DocumentReviewer")
  documentsApproved          DocumentFile[]             @relation("DocumentApprover")
  documentVersions           DocumentVersion[]
  documentComments           DocumentComment[]
  notes                      Note[]
  timeEntries                TimeEntry[]
  expensesSubmitted          Expense[]
  communicationLogs          CommunicationLog[]
  announcements              Announcement[]
  activityLogs               ActivityLog[]
  knowledgeArticles          KnowledgeArticle[]
  sessions                   Session[]
  notifications              Notification[]
  leaveRequests              LeaveRequest[]             @relation("LeaveRequester")
  leaveApprovals             LeaveRequest[]             @relation("LeaveApprover")
  attendanceRecords          AttendanceRecord[]
  generatedDocumentsCreated  GeneratedDocument[]        @relation("GeneratedDocumentCreator")
  generatedDocumentsReviewed GeneratedDocument[]        @relation("GeneratedDocumentReviewer")
  generatedDocumentsApproved GeneratedDocument[]        @relation("GeneratedDocumentApprover")
  generatedDocumentVersions  GeneratedDocumentVersion[]
  researchBookmarks          ResearchBookmark[]
  researchNotes              ResearchNote[]

  createdAt DateTime @default(now())
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────
// Clients & matters
// ─────────────────────────────────────────────────────────────────────────

model Client {
  id                    String       @id @default(cuid())
  clientNumber          String       @unique
  type                  ClientType   @default(COMPANY)
  name                  String
  companyName           String?
  industry              String?
  email                 String?
  phone                 String?
  addressLine1          String?
  addressLine2          String?
  city                  String?
  state                 String?
  country               String?
  postalCode            String?
  taxId                 String?
  status                ClientStatus @default(ACTIVE)
  source                String?
  tags                  String?
  avatarUrl             String?
  relationshipManagerId String?
  relationshipManager   User?        @relation("RelationshipManager", fields: [relationshipManagerId], references: [id])
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  matters            Matter[]
  invoices           Invoice[]
  payments           Payment[]
  documents          DocumentFile[]
  documentFolders    DocumentFolder[]
  notes              Note[]
  meetings           Meeting[]
  communicationLogs  CommunicationLog[]
  retainers          Retainer[]
  expenses           Expense[]
  activityLogs       ActivityLog[]
  companies          Company[]
  contacts           Contact[]
  portalUsers        User[]              @relation("PortalUser")
  generatedDocuments GeneratedDocument[]
}

model Matter {
  id                    String       @id @default(cuid())
  matterNumber          String       @unique
  title                 String
  description           String?
  clientId              String
  client                Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  practiceAreaId        String
  practiceArea          PracticeArea @relation(fields: [practiceAreaId], references: [id])
  status                MatterStatus @default(INTAKE)
  stage                 MatterStage  @default(MATTER_CREATED)
  priority              Priority     @default(MEDIUM)
  billingType           BillingType  @default(HOURLY)
  hourlyRate            Float?
  estimatedValue        Float?
  openedDate            DateTime     @default(now())
  targetCloseDate       DateTime?
  closedDate            DateTime?
  opposingParty         String?
  opposingCounsel       String?
  responsibleAttorneyId String
  responsibleAttorney   User         @relation("ResponsibleAttorney", fields: [responsibleAttorneyId], references: [id])
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  team               MatterTeamMember[]
  hearings           Hearing[]
  tasks              Task[]
  documents          DocumentFile[]
  documentFolders    DocumentFolder[]
  notes              Note[]
  meetings           Meeting[]
  communicationLogs  CommunicationLog[]
  invoices           Invoice[]
  expenses           Expense[]
  retainers          Retainer[]
  timeEntries        TimeEntry[]
  activityLogs       ActivityLog[]
  courtCase          CourtCase?
  notifications      Notification[]
  generatedDocuments GeneratedDocument[]
  researchNotes      ResearchNote[]
}

model MatterTeamMember {
  id       String         @id @default(cuid())
  matterId String
  matter   Matter         @relation(fields: [matterId], references: [id], onDelete: Cascade)
  userId   String
  user     User           @relation(fields: [userId], references: [id])
  role     MatterTeamRole @default(SUPPORT)

  @@unique([matterId, userId])
}

model Company {
  id           String   @id @default(cuid())
  name         String
  industry     String?
  website      String?
  phone        String?
  email        String?
  addressLine1 String?
  city         String?
  state        String?
  country      String?
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  contacts Contact[]
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  title     String?
  email     String?
  phone     String?
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  isPrimary Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
}

model Hearing {
  id              String        @id @default(cuid())
  matterId        String
  matter          Matter        @relation(fields: [matterId], references: [id], onDelete: Cascade)
  courtName       String
  courtroom       String?
  judge           String?
  hearingType     String
  scheduledAt     DateTime
  status          HearingStatus @default(SCHEDULED)
  outcome         String?
  notes           String?
  nextHearingDate DateTime?
  createdAt       DateTime      @default(now())
}

model CourtCase {
  id              String    @id @default(cuid())
  matterId        String    @unique
  matter          Matter    @relation(fields: [matterId], references: [id], onDelete: Cascade)
  caseNumber      String
  courtType       CourtType
  courtName       String
  filingDate      DateTime?
  judge           String?
  stage           CaseStage @default(FILING)
  nextHearingDate DateTime?
  /// Statute-of-limitations deadline for this case — feeds the Risk Analysis Engine's upcoming-limitation-period rule.
  limitationDate  DateTime?
  createdAt       DateTime  @default(now())
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  matterId    String?
  matter      Matter?    @relation(fields: [matterId], references: [id], onDelete: Cascade)
  assigneeId  String
  assignee    User       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById String
  createdBy   User       @relation("TaskCreator", fields: [createdById], references: [id])
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
}

// ─────────────────────────────────────────────────────────────────────────
// Documents
// ─────────────────────────────────────────────────────────────────────────

model DocumentFolder {
  id        String           @id @default(cuid())
  name      String
  parentId  String?
  parent    DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  DocumentFolder[] @relation("FolderTree")
  matterId  String?
  matter    Matter?          @relation(fields: [matterId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  documents DocumentFile[]
}

model DocumentFile {
  id                   String          @id @default(cuid())
  name                 String
  folderId             String?
  folder               DocumentFolder? @relation(fields: [folderId], references: [id])
  matterId             String?
  matter               Matter?         @relation(fields: [matterId], references: [id], onDelete: Cascade)
  clientId             String?
  client               Client?         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fileType             String
  sizeBytes            Int             @default(0)
  storagePath          String
  version              Int             @default(1)
  tags                 String?
  status               DocumentStatus  @default(DRAFT)
  isArchived           Boolean         @default(false)
  isShared             Boolean         @default(false)
  uploadedById         String
  uploadedBy           User            @relation(fields: [uploadedById], references: [id])
  reviewedById         String?
  reviewedBy           User?           @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  approvedById         String?
  approvedBy           User?           @relation("DocumentApprover", fields: [approvedById], references: [id])
  submittedForReviewAt DateTime?
  approvedAt           DateTime?
  clientApprovedAt     DateTime?
  signedAt             DateTime?
  filedAt              DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  versions                DocumentVersion[]
  comments                DocumentComment[]
  generatedDocumentSource GeneratedDocument?
}

model DocumentComment {
  id         String       @id @default(cuid())
  documentId String
  document   DocumentFile @relation(fields: [documentId], references: [id], onDelete: Cascade)
  authorId   String
  author     User         @relation(fields: [authorId], references: [id])
  body       String
  createdAt  DateTime     @default(now())
}

model DocumentVersion {
  id           String       @id @default(cuid())
  documentId   String
  document     DocumentFile @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version      Int
  storagePath  String
  note         String?
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime     @default(now())
}

model Template {
  id          String           @id @default(cuid())
  name        String
  category    TemplateCategory
  description String?
  storagePath String?
  isFavorite  Boolean          @default(false)
  usageCount  Int              @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime         @default(now())
}

enum ClauseRiskLevel {
  LOW
  MEDIUM
  HIGH
}

model Clause {
  id               String          @id @default(cuid())
  title            String
  category         String
  body             String
  tags             String?
  jurisdiction     String?
  language         String          @default("en")
  riskLevel        ClauseRiskLevel @default(LOW)
  /// Comma-joined Clause ids this clause is commonly paired/contrasted with — same convention as `tags`.
  relatedClauseIds String?
  isFavorite       Boolean         @default(false)
  usageCount       Int             @default(0)
  lastUsedAt       DateTime?
  createdAt        DateTime        @default(now())
}

// ─────────────────────────────────────────────────────────────────────────
// AI Document Generator — structured-input document drafting, independent of
// the file-based Template model above (which stores uploaded template files,
// not fillable field schemas). See docs/DOCUMENT_GENERATION.md.
// ─────────────────────────────────────────────────────────────────────────

enum GeneratedDocumentType {
  LEGAL_NOTICE
  NDA
  EMPLOYMENT_AGREEMENT
  SERVICE_AGREEMENT
  VENDOR_AGREEMENT
  SHAREHOLDER_AGREEMENT
  POWER_OF_ATTORNEY
  AFFIDAVIT
  WILL
  LEASE_AGREEMENT
  PARTNERSHIP_DEED
  PRIVACY_POLICY
  TERMS_AND_CONDITIONS
  GENERAL_CONTRACT
  CORPORATE_RESOLUTION
}

enum GeneratedDocumentStatus {
  DRAFT
  IN_REVIEW
  REVISION_REQUESTED
  APPROVED
  EXPORTED
}

model GeneratedDocument {
  id                 String                  @id @default(cuid())
  documentType       GeneratedDocumentType
  title              String
  status             GeneratedDocumentStatus @default(DRAFT)
  /// JSON-encoded structured form input the document was generated from — the source of truth for regeneration.
  formData           String
  /// Current generated text (plain text/Markdown) — mirrors the latest GeneratedDocumentVersion.
  content            String
  version            Int                     @default(1)
  matterId           String?
  matter             Matter?                 @relation(fields: [matterId], references: [id], onDelete: SetNull)
  clientId           String?
  client             Client?                 @relation(fields: [clientId], references: [id], onDelete: SetNull)
  /// Populated when the doc type's structured fields include an end/expiry date — feeds the Risk Analysis Engine.
  expiresAt          DateTime?
  createdById        String
  createdBy          User                    @relation("GeneratedDocumentCreator", fields: [createdById], references: [id])
  reviewedById       String?
  reviewedBy         User?                   @relation("GeneratedDocumentReviewer", fields: [reviewedById], references: [id])
  approvedById       String?
  approvedBy         User?                   @relation("GeneratedDocumentApprover", fields: [approvedById], references: [id])
  revisionNote       String?
  /// Set once exported into the real Documents module — see features/document-generator/actions.ts's exportGeneratedDocument.
  exportedDocumentId String?                 @unique
  exportedDocument   DocumentFile?           @relation(fields: [exportedDocumentId], references: [id])
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  versions GeneratedDocumentVersion[]
}

model GeneratedDocumentVersion {
  id                  String            @id @default(cuid())
  generatedDocumentId String
  generatedDocument   GeneratedDocument @relation(fields: [generatedDocumentId], references: [id], onDelete: Cascade)
  version             Int
  content             String
  note                String?
  createdById         String
  createdBy           User              @relation(fields: [createdById], references: [id])
  createdAt           DateTime          @default(now())
}

// ─────────────────────────────────────────────────────────────────────────
// Legal Research Assistant — bookmarking + a research notebook over the
// existing KnowledgeArticle-backed Research module. See docs/KNOWLEDGE_ENGINE.md.
// ─────────────────────────────────────────────────────────────────────────

model ResearchBookmark {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId String
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([userId, articleId])
}

model ResearchNote {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId String?
  article   KnowledgeArticle? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  matterId  String?
  matter    Matter?           @relation(fields: [matterId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime          @default(now())
}

// ─────────────────────────────────────────────────────────────────────────
// Billing & finance
// ─────────────────────────────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  matterId      String?
  matter        Matter?       @relation(fields: [matterId], references: [id])
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  subtotal      Float         @default(0)
  taxAmount     Float         @default(0)
  discount      Float         @default(0)
  total         Float         @default(0)
  amountPaid    Float         @default(0)
  currency      String        @default("INR")
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lineItems InvoiceLineItem[]
  payments  Payment[]
}

model InvoiceLineItem {
  id          String       @id @default(cuid())
  invoiceId   String
  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float        @default(1)
  rate        Float
  amount      Float
  type        LineItemType @default(FEE)
}

model Payment {
  id        String        @id @default(cuid())
  invoiceId String
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id])
  amount    Float
  method    PaymentMethod @default(BANK_TRANSFER)
  reference String?
  paidAt    DateTime      @default(now())
}

model Expense {
  id            String   @id @default(cuid())
  matterId      String?
  matter        Matter?  @relation(fields: [matterId], references: [id], onDelete: Cascade)
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])
  category      String
  description   String
  amount        Float
  incurredAt    DateTime @default(now())
  billable      Boolean  @default(true)
  reimbursed    Boolean  @default(false)
  submittedById String
  submittedBy   User     @relation(fields: [submittedById], references: [id])
  createdAt     DateTime @default(now())
}

model Retainer {
  id        String         @id @default(cuid())
  clientId  String
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  matterId  String?
  matter    Matter?        @relation(fields: [matterId], references: [id])
  amount    Float
  balance   Float
  status    RetainerStatus @default(ACTIVE)
  startDate DateTime       @default(now())
  createdAt DateTime       @default(now())
}

model TimeEntry {
  id          String   @id @default(cuid())
  matterId    String
  matter      Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime @default(now())
  minutes     Int
  description String
  billable    Boolean  @default(true)
  rate        Float?
  invoiced    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────
// Collaboration
// ─────────────────────────────────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  matterId  String?
  matter    Matter?  @relation(fields: [matterId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Meeting {
  id              String        @id @default(cuid())
  matterId        String?
  matter          Matter?       @relation(fields: [matterId], references: [id], onDelete: Cascade)
  clientId        String?
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title           String
  scheduledAt     DateTime
  durationMinutes Int           @default(30)
  location        String?
  attendees       String?
  notes           String?
  status          MeetingStatus @default(SCHEDULED)
  createdAt       DateTime      @default(now())
}

model CommunicationLog {
  id         String            @id @default(cuid())
  matterId   String?
  matter     Matter?           @relation(fields: [matterId], references: [id], onDelete: Cascade)
  clientId   String?
  client     Client?           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type       CommunicationType
  subject    String
  summary    String?
  occurredAt DateTime          @default(now())
  loggedById String
  loggedBy   User              @relation(fields: [loggedById], references: [id])
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  body        String
  priority    AnnouncementPriority @default(NORMAL)
  publishedAt DateTime             @default(now())
  expiresAt   DateTime?
  createdById String
  createdBy   User                 @relation(fields: [createdById], references: [id])
}

model CourtListEntry {
  id                String    @id @default(cuid())
  name              String
  type              CourtType
  city              String?
  state             String?
  address           String?
  phone             String?
  email             String?
  caseNumberPattern String?
  createdAt         DateTime  @default(now())
}

model KnowledgeArticle {
  id                String   @id @default(cuid())
  title             String
  category          String
  summary           String?
  body              String
  tags              String?
  /// Comma-joined KnowledgeArticle ids — cross-references between related articles/precedents.
  relatedArticleIds String?
  authorId          String
  author            User     @relation(fields: [authorId], references: [id])
  publishedAt       DateTime @default(now())
  viewCount         Int      @default(0)

  bookmarks ResearchBookmark[]
  notes     ResearchNote[]
}

model ActivityLog {
  id            String   @id @default(cuid())
  action        String
  entityType    String
  entityId      String
  previousValue String?
  currentValue  String?
  source        String   @default("APP")
  matterId      String?
  matter        Matter?  @relation(fields: [matterId], references: [id], onDelete: Cascade)
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  actorId       String
  actor         User     @relation(fields: [actorId], references: [id])
  createdAt     DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────
// Notifications & HR
// ─────────────────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  matterId  String?
  matter    Matter?          @relation(fields: [matterId], references: [id], onDelete: Cascade)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
}

model LeaveRequest {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  type         LeaveType
  startDate    DateTime
  endDate      DateTime
  days         Float
  reason       String?
  status       LeaveStatus @default(PENDING)
  approvedById String?
  approvedBy   User?       @relation("LeaveApprover", fields: [approvedById], references: [id])
  createdAt    DateTime    @default(now())
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  checkIn   DateTime?
  checkOut  DateTime?
  createdAt DateTime         @default(now())

  @@unique([userId, date])
}
