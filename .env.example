# Copy to .env and adjust. Every LEXORA_* var below is optional — the app
# works with zero external services and every default shown here.

DATABASE_URL="file:./prisma/dev.db"

# --- Enterprise/SaaS-readiness layer (src/lib/platform) -------------------
# All optional. Leaving these unset keeps the app exactly as it behaves
# locally today — see docs/CONFIGURATION.md and docs/FUTURE_INTEGRATIONS.md.

# Multi-tenancy — inert scaffolding only; there is no real multi-tenant
# implementation to enable yet. Leave false.
# LEXORA_MULTI_TENANCY_ENABLED=false

# Storage provider: local | s3 | azure-blob | gcs (only "local" has a real implementation)
# LEXORA_STORAGE_PROVIDER=local

# Comma-separated notification channels: in-app | email | sms | whatsapp | push | desktop
# (only "in-app" is real; others log to console via a mock channel)
# LEXORA_NOTIFICATION_CHANNELS=in-app

# AI provider: mock | openai | anthropic | gemini (only "mock" is implemented)
# LEXORA_AI_PROVIDER=mock

# Payment provider: mock | stripe | razorpay (only "mock" is implemented)
# LEXORA_PAYMENT_PROVIDER=mock

# Cache backend: memory | redis (only "memory" is implemented)
# LEXORA_CACHE_PROVIDER=memory

# Log sink: console | cloud (only "console" is implemented; "cloud" falls back to console with a warning)
# LEXORA_LOG_PROVIDER=console
# LEXORA_LOG_LEVEL=info

# Regional defaults
# LEXORA_DEFAULT_LOCALE=en-IN
# LEXORA_DEFAULT_CURRENCY=INR
# LEXORA_DEFAULT_TIMEZONE=Asia/Kolkata
# LEXORA_APP_BASE_URL=http://localhost:3000

# --- Future provider credentials (unused until a real adapter is written) --
# STRIPE_SECRET_KEY=
# RAZORPAY_KEY_ID=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LEXORA_S3_BUCKET=
# REDIS_URL=
